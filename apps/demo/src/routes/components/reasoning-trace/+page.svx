<script lang="ts">
	import { ReasoningTrace } from 'ukiyoe/agentic';
	import { PageHeader } from 'ukiyoe/core';
	import ComponentPreview from '$lib/ComponentPreview.svelte';
	import PropsTable, { type PropDef } from '$lib/PropsTable.svelte';

	const propDefs: PropDef[] = [
		{ name: 'content', type: 'string', default: '-', description: 'Reasoning content text (required)' },
		{ name: 'expanded', type: 'boolean', default: 'false', description: 'Whether the trace is expanded (bindable)' },
		{ name: 'class', type: 'string', default: "''", description: 'Additional CSS classes' }
	];

	const sampleReasoning = `The user is asking about component libraries. Let me think about the best way to explain this.

I should cover:
1. Svelte 5 runes and the new reactivity model
2. Snippets replacing slots for composition
3. The dark-first design approach with CSS variables

Let me structure the response to be clear and informative.`;
</script>

<svelte:head>
	<title>ReasoningTrace - Ukiyoe UI</title>
</svelte:head>

<PageHeader title="ReasoningTrace" subtitle="Collapsible reasoning trace for AI model thinking content" />

