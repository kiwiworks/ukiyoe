{
	"name": "ukiyoe",
	"version": "0.6.0",
	"description": "Svelte 5 component library with dark-first design",
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": ["**/*.css"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./core": {
			"types": "./dist/core/index.d.ts",
			"svelte": "./dist/core/index.js",
			"default": "./dist/core/index.js"
		},
		"./layout": {
			"types": "./dist/layout/index.d.ts",
			"svelte": "./dist/layout/index.js",
			"default": "./dist/layout/index.js"
		},
		"./viz": {
			"types": "./dist/viz/index.d.ts",
			"svelte": "./dist/viz/index.js",
			"default": "./dist/viz/index.js"
		},
		"./effects": {
			"types": "./dist/effects/index.d.ts",
			"svelte": "./dist/effects/index.js",
			"default": "./dist/effects/index.js"
		},
		"./agentic": {
			"types": "./dist/agentic/index.d.ts",
			"svelte": "./dist/agentic/index.js",
			"default": "./dist/agentic/index.js"
		},
		"./openapi": {
			"types": "./dist/openapi/index.d.ts",
			"svelte": "./dist/openapi/index.js",
			"default": "./dist/openapi/index.js"
		},
		"./styles.css": "./dist/styles.css",
		"./tailwind.preset": "./tailwind.preset.ts"
	},
	"files": [
		"dist",
		"tailwind.preset.ts"
	],
	"scripts": {
		"build": "svelte-kit sync && svelte-package",
		"build:strict": "bun run build && bun run check:dts",
		"check": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"check:dts": "node scripts/verify-package-types.mjs",
		"test": "vitest",
		"test:run": "vitest run",
		"lint": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "bun run build:strict && bun run check && bun run test:run && bun run lint"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kiwiworks/ukiyoe.git"
	},
	"keywords": [
		"svelte",
		"svelte5",
		"components",
		"ui",
		"design-system",
		"dark-mode"
	],
	"author": "kiwiworks",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/kiwiworks/ukiyoe/issues"
	},
	"homepage": "https://github.com/kiwiworks/ukiyoe#readme",
	"peerDependencies": {
		"@internationalized/date": "^3.0.0",
		"@lucide/svelte": "^0.576.0",
		"bits-ui": "^2.0.0",
		"shiki": "^3.0.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0",
		"zod": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"shiki": {
			"optional": true
		},
		"zod": {
			"optional": true
		}
	},
	"devDependencies": {
		"@eslint/js": "^9.39.0",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/package": "^2.3.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"eslint": "^9.39.0",
		"eslint-plugin-svelte": "^3.15.0",
		"happy-dom": "^20.8.0",
		"prettier": "^3.8.0",
		"prettier-plugin-svelte": "^3.5.0",
		"shiki": "^3.23.0",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.0",
		"typescript": "^5.9.0",
		"vite": "^6.4.0",
		"vitest": "^3.0.0",
		"zod": "^4.0.0"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.0",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/lang-yaml": "^6.1.2",
		"@codemirror/search": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@scalar/openapi-parser": "^0.24.1",
		"ajv": "^8.17.1",
		"clsx": "^2.1.1",
		"codemirror": "^6.0.2",
		"marked": "^15.0.0",
		"tailwind-merge": "^3.4.0"
	}
}
